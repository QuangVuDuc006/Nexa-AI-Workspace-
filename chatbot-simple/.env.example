GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash
FLASK_DEBUG=false
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-string
# Optional. Defaults to a key derived from SECRET_KEY.
PROVIDER_CREDENTIAL_KEY=
DATABASE_URL=sqlite:///instance/chatbot.sqlite3
UPLOAD_STORAGE_DIR=instance/uploads
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
CSRF_ENABLED=true
ADMIN_EMAILS=
ADMIN_UIDS=
RATE_LIMIT_WINDOW_SECONDS=60
CHAT_RATE_LIMIT_PER_WINDOW=30
API_RATE_LIMIT_PER_WINDOW=120
MAX_UPLOAD_BYTES=12582912
MAX_IMAGE_BYTES=5242880
AI_REQUEST_TIMEOUT=60

AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Firebase web app config for Firebase Authentication
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin SDK verification
FIREBASE_PROJECT_ID=
# Render: set FIREBASE_CREDENTIALS to the complete service account JSON.
# Local development falls back to the repository-root firebase-adminsdk JSON file.
# FIREBASE_CREDENTIALS=
