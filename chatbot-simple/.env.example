# development or production
APP_ENV=development
FLASK_DEBUG=false

# Production: use long random values and keep them stable.
SECRET_KEY=change-me

# Production: required and must be PostgreSQL.
DATABASE_URL=sqlite:///instance/chatbot.sqlite3

# Dedicated Fernet secret for encrypted provider API keys.
# Changing this later makes existing encrypted provider keys undecryptable until key rotation is implemented.
PROVIDER_CREDENTIAL_KEY=change-me-provider-credential-key

# Flask session lifetime. Production default is one day unless changed.
SESSION_LIFETIME_MINUTES=1440
SESSION_COOKIE_SAMESITE=Lax

# Firebase web config used by login/register pages.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin credentials. Prefer FIREBASE_CREDENTIALS_JSON in hosted deployments.
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS=

# Auth access policy.
# Production: set AUTH_ALLOW_PUBLIC_SIGNIN=true only for intentionally open sign-in.
AUTH_ALLOW_PUBLIC_SIGNIN=false
AUTH_REQUIRE_EMAIL_VERIFIED=true
AUTH_ALLOWED_EMAIL_DOMAINS=
AUTH_ALLOWED_EMAILS=

# Optional admin mapping for signed-in Firebase users.
ADMIN_EMAILS=
ADMIN_UIDS=

CSRF_ENABLED=true
UPLOAD_STORAGE_DIR=instance/uploads
MAX_UPLOAD_MB=10
MAX_DOCUMENTS_PER_USER=0
MAX_UPLOAD_STORAGE_MB_PER_USER=75
MAX_CONVERSATIONS_PER_USER=100
MAX_MEMORIES_PER_USER=30
MAX_PROVIDER_CONNECTIONS_PER_USER=5
MAX_IMAGE_BYTES=5242880

# Local/dev can use memory. Production must use Redis so limits survive restarts
# and work across multiple app instances.
RATE_LIMIT_BACKEND=memory
REDIS_URL=
RATE_LIMIT_FAIL_OPEN=false
RATE_LIMIT_AUTH=10 per minute
RATE_LIMIT_API=120 per minute
RATE_LIMIT_CHAT=30 per minute
RATE_LIMIT_STREAM=30 per minute
RATE_LIMIT_UPLOAD=10 per hour
RATE_LIMIT_PROVIDER_TEST=20 per hour
RATE_LIMIT_MEMORY=60 per minute
RATE_LIMIT_DOCUMENTS=60 per minute

AI_REQUEST_TIMEOUT=180
AI_MAX_OUTPUT_TOKENS=8192

NEXA_MEMORY_DEBUG=false
RAG_ENABLED=true
VECTOR_STORE=simple
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hash-embedding
EMBEDDING_API_KEY=
RAG_TOP_K=5
RAG_CHUNK_SIZE_CHARS=1500
RAG_CHUNK_OVERLAP_CHARS=250
